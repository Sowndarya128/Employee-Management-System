from flask import Flask, render_template,request,redirect,flash
import pyodbc

app = Flask(__name__)
app.secret_key = "employee_management_secret "

@app.route("/")
def home():
    conn= pyodbc.connect(
            "DRIVER={ODBC Driver 17 for SQL Server};"
            "SERVER=STUNNER;"
            "DATABASE=StudentDB;"
            "Trusted_connection=yes;"
        )
    cursor = conn.cursor()
    search = request.args.get("search","")
    if search:
        cursor.execute(
            """
            SELECT * FROM Employee 
            WHERE name LIKE ?
            OR department LIKE ?
            """,
            ('%' + search + '%', '%' + search + '%',)
            )
    else:
         cursor.execute("SELECT * FROM Employee")
    rows = cursor.fetchall()
    employee_count = len(rows)
    conn.close()

    return render_template("index.html", employees=rows, search=search, employee_count=employee_count)
@app.route("/add",methods=["GET","POST"])
def add_employee():
    if request.method == "POST":
        name = request.form["name"]
        department = request.form["department"]
        salary = request.form["salary"]
        if not name.strip():
            flash("Name cannot be empty", "danger")
            return redirect("/add")
        if not department.strip():
            flash("Department cannot be empty", "danger")
            return redirect("/add")
        if int(salary) <= 0:
            flash("Sallary must be greater than 0", "danger")
            return redirect("/add")
        conn= pyodbc.connect(
            "DRIVER={ODBC Driver 17 for SQL Server};"
            "SERVER=STUNNER;"
            "DATABASE=StudentDB;"
            "Trusted_connection=yes;"
        )
        cursor = conn.cursor()
        cursor.execute(
            """
        INSERT INTO Employee(name, department, salary)
        VALUES (?, ?, ?)
        """,
        (name, department, salary)
        )
        conn.commit()
        conn.close()

        flash("Employee Added Successfully!", "success")
        return redirect("/")
       
    return render_template("add_employee.html")

@app.route("/edit/<int:id>", methods=["GET", "POST"])
def edit_employee(id):
    conn = pyodbc.connect(
        "DRIVER={ODBC Driver 17 for SQL Server};"
        "SERVER=STUNNER;"
        "DATABASE=StudentDB;"
        "Trusted_Connection=yes;"
    )
    cursor = conn.cursor()
    if request.method == "POST":
        name = request.form["name"]
        department = request.form["department"]
        salary = request.form["salary"]

        cursor.execute(
        """
            UPDATE Employee
            SET name=?, department=?, salary=?
            WHERE id=?
            """,
            (name, department, salary, id)
    )
        conn.commit()
        conn.close()
        flash("Employee Updated Successfully", "info")

        return redirect("/")
    
    cursor.execute(
        "SELECT * FROM Employee WHERE id=?",
        (id,)
    )

    employee = cursor.fetchone()
    conn.close()

    return render_template("edit_employee.html", employee=employee)
@app.route("/delete/<int:id>")
def delete_employee(id):
    conn = pyodbc.connect(
        "DRIVER={ODBC Driver 17 for SQL Server};"
        "SERVER=STUNNER;"
        "DATABASE=StudentDB;"
        "Trusted_Connection=yes;"
    )
    cursor = conn.cursor()
    cursor.execute(
        "DELETE FROM Employee WHERE id=?",
        (id,)
    )
    conn.commit()
    conn.close()
    flash("Employee Deleted Successfully","warning")
    
    return redirect("/")



if __name__ == "__main__":
    app.run(debug=True)
